rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "princekumarjha83@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isOfficer() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'officer' || isAdmin());
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && 
        hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'phoneNumber', 'createdAt']) &&
        request.resource.data.role == 'user'; // Default role is user
      allow update: if isOwner(userId) && 
        request.resource.data.role == resource.data.role || isAdmin();
    }

    // Crime Reports
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || isOfficer());
      allow create: if isAuthenticated() && 
        request.resource.data.reporterId == request.auth.uid &&
        request.resource.data.status == 'submitted';
      allow update: if isOfficer() || (isAuthenticated() && resource.data.reporterId == request.auth.uid && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isOfficer();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
